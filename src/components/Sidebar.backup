"use client";

import React from "react";
import Link from "next/link";
import { usePathname } from "next/navigation";
import { 
  LayoutDashboard, 
  Compass, 
  Droplet, 
  Cpu, 
  Activity, 
  Wallet, 
  Code, 
  Trophy, 
  BookOpen, 
  Terminal,
  Layers,
  LogOut,
  User,
  Award,
  Gamepad2,
  RefreshCw
} from "lucide-react";
import { useWallet } from "../contexts/WalletContext";
import { useQuests } from "../contexts/QuestContext";

const navItems = [
  { name: "Dashboard", path: "/", icon: LayoutDashboard },
  { name: "Getting Started", path: "/getting-started", icon: Compass },
  { name: "Faucet", path: "/faucet", icon: Droplet },
  { name: "Explorer", path: "/explorer", icon: Activity },
  { name: "Wallet Tools", path: "/wallet-tools", icon: Wallet },
  { name: "Deploy Contracts", path: "/deploy", icon: Code },
  { name: "KiiSwap DEX", path: "/kiiswap", icon: RefreshCw },
  { name: "Testnet Quests", path: "/quests", icon: Trophy },
  { name: "Kii Arcade", path: "/gaming", icon: Gamepad2 },
  { name: "Builder Profile", path: "/profile", icon: User },
  { name: "Hall of Fame", path: "/hall-of-fame", icon: Award },
];

export const Sidebar: React.FC = () => {
  const pathname = usePathname();
  const { 
    isConnected, 
    walletType, 
    displayAddress, 
    disconnectWallet, 
    balance 
  } = useWallet();
  
  const { level, totalXp, profileUsername, profileTitle, profileAvatar } = useQuests();

  const truncateAddress = (addr: string) => {
    return `${addr.slice(0, 6)}...${addr.slice(-4)}`;
  };

  return (
    <aside className="w-64 h-screen border-r border-brand-border bg-brand-black/90 flex flex-col justify-between select-none fixed left-0 top-0 z-40 backdrop-blur-xl">
      {/* Top Section - Logo & Level */}
      <div className="flex flex-col pt-6 overflow-y-auto flex-1">
        {/* Logo */}
        <div className="px-6 pb-6 border-b border-brand-border/40">
          <Link href="/" className="flex items-center gap-3 group">
            <div className="w-8 h-8 rounded-lg bg-gradient-to-tr from-kii-purple to-kii-blue flex items-center justify-center shadow-lg shadow-kii-purple/20 group-hover:scale-105 transition-transform duration-300">
              <Layers className="w-4 h-4 text-white" />
            </div>
            <div>
              <span className="font-bold text-white tracking-wide text-md">Kii Builder</span>
              <span className="text-kii-blue font-semibold text-xs ml-1 bg-kii-blue/10 px-1.5 py-0.5 rounded-md border border-kii-blue/20">HUB</span>
            </div>
          </Link>
          
          {/* Level Progress */}
          <div className="mt-5 p-3 rounded-lg bg-white/[0.02] border border-white/[0.04] flex items-center justify-between gap-2">
            <div className="flex items-center gap-2.5 min-w-0">
              <div className="w-8 h-8 rounded-md bg-kii-purple/15 flex items-center justify-center text-lg border border-kii-purple/20 flex-shrink-0">
                {profileAvatar}
              </div>
              <div className="flex flex-col min-w-0">
                <span className="text-xs font-bold text-white truncate">{profileUsername}</span>
                <span className="text-[10px] text-zinc-400 font-medium truncate">{profileTitle} (L{level})</span>
              </div>
            </div>
            <div className="text-[9px] font-bold text-kii-blue font-mono px-1.5 py-0.5 rounded bg-kii-blue/10 border border-kii-blue/20 flex-shrink-0">
              {totalXp} XP
            </div>
          </div>
        </div>

        {/* Nav Links */}
        <nav className="mt-4 px-3 space-y-1">
          {navItems.map((item) => {
            const isActive = pathname === item.path;
            const Icon = item.icon;
            
            return (
              <Link
                key={item.name}
                href={item.path}
                className={`flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-all duration-200 group ${
                  isActive
                    ? "bg-gradient-to-r from-kii-purple/20 to-kii-blue/5 text-white border border-brand-border-purple/35 shadow-md shadow-kii-purple/5"
                    : "text-zinc-400 hover:text-zinc-200 hover:bg-white/[0.03] border border-transparent"
                }`}
              >
                <Icon className={`w-4.5 h-4.5 transition-colors ${
                  isActive ? "text-kii-blue" : "text-zinc-500 group-hover:text-zinc-300"
                }`} />
                <span>{item.name}</span>
                {item.name === "Contract Playground" && (
                  <span className="ml-auto text-[9px] font-bold text-kii-teal border border-kii-teal/20 px-1 py-0.2 rounded bg-kii-teal/10 animate-pulse">
                    NEW
                  </span>
                )}
              </Link>
            );
          })}
        </nav>
      </div>

      {/* Bottom Section - Wallet Status */}
      <div className="p-4 border-t border-brand-border/40 bg-brand-dark/50 space-y-3">

        {/* Wallet Status Area */}
        {isConnected && displayAddress ? (
          <div className="p-3 rounded-lg bg-zinc-900/60 border border-brand-border flex items-center justify-between">
            <div className="flex flex-col min-w-0">
              <span className="text-[10px] text-zinc-400 capitalize font-medium">
                {walletType} Connected
              </span>
              <span className="text-xs font-bold text-white truncate max-w-[120px]">
                {truncateAddress(displayAddress)}
              </span>
              <span className="text-[10px] text-kii-blue font-bold mt-0.5">
                {balance} KII
              </span>
            </div>
            <button
              onClick={disconnectWallet}
              className="p-1.5 rounded-md hover:bg-red-500/10 text-zinc-500 hover:text-red-400 transition-colors"
              title="Disconnect Wallet"
            >
              <LogOut className="w-3.5 h-3.5" />
            </button>
          </div>
        ) : (
          <Link
            href="/wallet-tools"
            className="w-full flex items-center justify-center gap-2 py-2.5 px-4 rounded-lg bg-gradient-to-r from-kii-purple to-kii-blue hover:opacity-95 text-white font-bold text-xs tracking-wider uppercase transition-opacity shadow-lg shadow-kii-purple/10"
          >
            <Wallet className="w-4 h-4" />
            Connect Wallet
          </Link>
        )}
      </div>
    </aside>
  );
};
